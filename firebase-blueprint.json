{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "Public and private user information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "staff"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "role"]
    },
    "inventoryItem": {
      "title": "Inventory Item",
      "description": "Stock item information",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "currentStock": { "type": "number" },
        "unit": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "salesPrice": { "type": "number" },
        "manufactureDate": { "type": "string" },
        "expiryDate": { "type": "string" },
        "loss": { "type": "string" },
        "status": { "type": "string" },
        "location": { "type": "string" },
        "safetyStock": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sku", "name", "category", "currentStock", "unit"]
    },
    "productionBatch": {
      "title": "Production Batch",
      "description": "Information about a production batch",
      "type": "object",
      "properties": {
        "batchId": { "type": "string" },
        "productionLine": { "type": "string", "enum": ["삼산공장", "언양공장 식육가공", "언양공장 식육포장"] },
        "title": { "type": "string" },
        "rawMeat": { "type": "string" },
        "weight": { "type": "string" },
        "loss": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["batchId", "title", "weight"]
    },
    "logisticsRecord": {
      "title": "Logistics Record",
      "description": "Inbound and outbound logistics tracking",
      "type": "object",
      "properties": {
        "time": { "type": "string" },
        "type": { "type": "string", "enum": ["입고", "출고"] },
        "title": { "type": "string" },
        "partner": { "type": "string" },
        "qty": { "type": "string" },
        "status": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "partner", "qty", "status"]
    },
    "partner": {
      "title": "Business Partner",
      "description": "Suppliers and customers",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["공급사", "고객사"] },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles"
    },
    "/inventory/{itemId}": {
      "schema": "inventoryItem",
      "description": "Inventory items"
    },
    "/production_batches/{batchId}": {
      "schema": "productionBatch",
      "description": "Production history"
    },
    "/logistics/{recordId}": {
      "schema": "logisticsRecord",
      "description": "Logistics records"
    },
    "/partners/{partnerId}": {
      "schema": "partner",
      "description": "Business partners"
    }
  }
}
