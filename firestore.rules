rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection Test Path
    match /test/connection {
      allow read: if true;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'crucify87@gmail.com' ||
        exists(/databases/$(database)/documents/admin_emails/$(request.auth.token.email))
      );
    }

    // Helper for user validation
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'role']) &&
             data.keys().size() >= 3 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['admin', 'manager', 'staff'];
    }

    // Helper for inventory validation
    function isValidInventoryItem(data) {
      return data.keys().hasAll(['sku', 'name', 'category', 'currentStock', 'unit']) &&
             data.sku is string && data.sku.size() <= 50 &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.currentStock is number &&
             data.unit is string && data.unit.size() <= 20;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    // 2. Inventory Collection
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isEmailVerified();
      allow delete: if isSignedIn() && isEmailVerified();
    }

    // 3. Production Batches
    match /production_batches/{batchId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isEmailVerified();
      allow delete: if isSignedIn() && isEmailVerified();
    }

    // 4. Logistics
    match /logistics/{recordId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isEmailVerified();
      allow delete: if isSignedIn() && isEmailVerified();
    }

    // 5. Partners
    match /partners/{partnerId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isEmailVerified();
      allow delete: if isSignedIn() && isEmailVerified();
    }

    // 6. Admin Emails
    match /admin_emails/{email} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
    }
  }
}
